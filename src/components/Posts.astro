---
import { getCollection } from 'astro:content';
import DateTime from './DateTime.astro';

const blogPosts = await getCollection('blog');
---

<section class="px-2 pt-6">
	<hgroup>
		<h2 class="text-secondary">Posts</h2>
		<p>
			My humble attempt to record the journey of meandering through my mental
			maze; one musing at a time.
		</p>
	</hgroup>
	<div class="flex flex-col gap-y-4 pt-4">
		{
			blogPosts.map(({ data, slug }) => {
				return (
					<article class="bg-dark-surface-2 rounded-md">
						<a class="no-underline cursor-pointer">
							<hgroup class="p-3">
								<h3 class="text-primary font-bold">{data.title}</h3>
								<DateTime value={data.date} />
								<div class="h-2" />
								<p class="text-base">{data.subtitle}</p>
							</hgroup>
						</a>
					</article>
				);
			})
		}
	</div>
</section>

<style>
	.post-card {
	}
</style>
